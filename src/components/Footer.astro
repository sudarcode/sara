---
import Socials from "./Socials.astro";
import { withBase } from "@utils/base";

const currentYear = new Date().getFullYear();

export interface Props {
  noMarginTop?: boolean;
}

const { noMarginTop = false } = Astro.props;
---

<footer class:list={["footer-root", !noMarginTop && "footer-root--auto"]}>
  <div class="footer-divider"></div>

  <div class="footer-inner">
    <div class="footer-newsletter">
      <span class="footer-newsletter-title">Stay in the loop</span>
      <form class="footer-form" id="footer-subscribe">
        <input
          type="email"
          name="email"
          placeholder="your@email.com"
          required
          class="footer-input"
        />
        <button type="submit" class="footer-button">Subscribe</button>
      </form>
    </div>

    <div class="footer-mini-divider"></div>

    <div class="footer-signature">
      <span class="footer-signature-title">Yours Truly,</span>
      <span class="footer-signature-name">Nauval Sudarmanto</span>
      <div class="footer-signature-divider"></div>
    </div>

    <div class="footer-socials">
      <Socials centered />
    </div>

    <div class="footer-meta">
      <a href={withBase("/humans.txt")} class="footer-meta-link">&copy; 2020 - {currentYear}</a>
    </div>
  </div>
</footer>

<style>
  .footer-root {
    width: 100%;
  }

  .footer-root--auto {
    margin-top: auto;
  }

  .footer-divider {
    width: 100%;
    height: 1px;
    margin-bottom: 3rem;
    background: rgba(var(--color-line), 0.3);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    padding: 3rem 0;
  }

  .footer-newsletter {
    width: 100%;
    max-width: 20rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    text-align: center;
  }

  .footer-newsletter-title {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: rgba(var(--color-text-base), 0.6);
  }

  .footer-form {
    width: 100%;
    display: flex;
    gap: 0.5rem;
  }

  .footer-input {
    flex: 1;
    min-width: 0;
    padding: 0.375rem 0.75rem;
    border-radius: 2px;
    border: 1px solid rgba(var(--color-line), 0.4);
    background: rgba(var(--color-fill), 1);
    color: rgba(var(--color-text-base), 1);
    font-family: var(--font-mono);
    font-size: 12px;
    transition: border-color 180ms ease;
  }

  .footer-input::placeholder {
    color: rgba(var(--color-text-base), 0.6);
  }

  .footer-input:focus {
    outline: none;
    border-color: rgba(var(--color-accent), 1);
  }

  .footer-button {
    padding: 0.375rem 0.75rem;
    border: 0;
    border-radius: 2px;
    white-space: nowrap;
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(var(--color-accent), 1);
    background: rgba(var(--color-accent), 0.1);
    cursor: pointer;
    transition: background-color 180ms ease;
  }

  .footer-button:hover {
    background: rgba(var(--color-accent), 0.2);
  }

  .footer-mini-divider,
  .footer-signature-divider {
    width: 4rem;
    height: 1px;
    background: rgba(var(--color-line), 0.2);
  }

  .footer-mini-divider {
    background: rgba(var(--color-line), 0.1);
  }

  .footer-signature {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
  }

  .footer-signature-title {
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: rgba(var(--color-text-base), 0.6);
  }

  .footer-signature-name {
    font-family: var(--font-serif);
    font-size: 1.875rem;
    font-style: italic;
    letter-spacing: -0.02em;
    color: rgba(var(--color-text-base), 1);
  }

  .footer-signature-divider {
    margin-top: 0.5rem;
  }

  .footer-socials {
    transform: scale(0.9);
    opacity: 0.6;
    transition: opacity 180ms ease;
  }

  .footer-socials:hover {
    opacity: 1;
  }

  .footer-meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(var(--color-text-base), 0.6);
  }

  .footer-meta-link {
    color: inherit;
    transition: color 180ms ease;
  }

  .footer-meta-link:hover {
    color: rgba(var(--color-text-base), 1);
  }
</style>

<script>
  function initSubscribeForm() {
    const form = document.getElementById(
      "footer-subscribe",
    ) as HTMLFormElement | null;
    if (!form || form.dataset.bound) return;
    form.dataset.bound = "1";
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const email = new FormData(form).get("email") as string;
      if (!email) return;
      window.open(
        `https://shravangoswami.substack.com/subscribe?freeSignupEmail=${encodeURIComponent(email)}`,
        "_blank",
        "noopener",
      );
    });
  }
  initSubscribeForm();
  document.addEventListener("astro:after-swap", initSubscribeForm);
</script>
